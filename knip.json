{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "entry": [
    "src/app/**/route.ts",
    "src/server/**/*.ts",
    "src/bot/handlers/**/*.ts",
    "scripts/*.ts",
    "vercel.ts"
  ],
  "project": ["src/**/*.ts", "scripts/**/*.ts"],
  "ignoreExportsUsedInFile": true,
  "ignore": ["src/lib/ai/tools/**"]
}
