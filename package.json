{
  "name": "@purduehackers/wack-hacker",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered Discord bot for Purdue Hackers. Coordinates specialized subagents to manage Discord, GitHub, Linear, and Notion from Discord threads.",
  "keywords": [
    "ai",
    "ai-agent",
    "ai-sdk",
    "discord",
    "discord-bot",
    "nextjs",
    "purdue-hackers",
    "vercel",
    "workflow-devkit"
  ],
  "homepage": "https://github.com/purduehackers/wack-hacker#readme",
  "bugs": {
    "url": "https://github.com/purduehackers/wack-hacker/issues"
  },
  "license": "MIT",
  "author": "Purdue Hackers (https://purduehackers.com)",
  "contributors": [
    "Rayhan Noufal Arayilakath <me@rayhanadev.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/purduehackers/wack-hacker.git"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "bun scripts/compile-skills.ts && next build && bun scripts/register-commands.ts",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "validate": "bun run typecheck && bun run lint && bun run test",
    "knip": "knip",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.35",
    "@discordjs/core": "^2.4.0",
    "@discordjs/rest": "^2.6.1",
    "@figma/rest-api-spec": "^0.37.0",
    "@libsql/client": "^0.17.3",
    "@linear/sdk": "^82.1.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@notionhq/client": "^5.20.0",
    "@octokit/auth-app": "^8.2.0",
    "@opentelemetry/api": "^1.9.1",
    "@payloadcms/sdk": "^3.84.1",
    "@purduehackers/discord-markdown-utils": "^0.0.4",
    "@sentry/api": "^0.113.0",
    "@sentry/nextjs": "^10.50.0",
    "@t3-oss/env-core": "^0.13.11",
    "@upstash/redis": "^1.37.0",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.4.4",
    "@vercel/queue": "^0.1.6",
    "@vercel/sandbox": "^1.10.0",
    "@vercel/sdk": "^1.19.40",
    "ai": "^6.0.168",
    "codec-parser": "^2.5.0",
    "discord-api-types": "^0.38.47",
    "discord-interactions": "^4.4.0",
    "discord.js": "^14.26.3",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.13.0",
    "exa-js": "^2.12.1",
    "hono": "^4.12.14",
    "next": "^16.2.4",
    "octokit": "^5.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rehype-stringify": "^10.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "resend": "^6.12.2",
    "svix": "^1.92.2",
    "ulid": "^3.0.2",
    "unified": "^11.0.5",
    "workflow": "^4.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@factory/eslint-plugin": "^0.1.0",
    "@types/bun": "1.3.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260423.1",
    "@vercel/config": "^0.2.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "knip": "^6.6.2",
    "lint-staged": "^16.4.0",
    "oxclippy": "^0.2.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "vitest": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxfmt",
      "oxlint"
    ],
    "*.{json,jsonc}": [
      "oxfmt"
    ]
  },
  "engines": {
    "bun": "^1.3.10"
  },
  "packageManager": "bun@1.3.13"
}
