# Internal auth
# Shared bearer token between the gateway relay and the /api/discord/inbound endpoint.
INBOUND_SECRET=
# Vercel cron invocations send `Authorization: Bearer ${CRON_SECRET}`; must match this.
CRON_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_ORG=purduehackers

# Linear
LINEAR_API_KEY=

# Notion
NOTION_TOKEN=

# Purdue Hackers Knowledge Base (ask.purduehackers.com)
PHACK_ASK_API_KEY=

# Dashboard + Phonebell (Purdue Hackers internal services)
PHACK_API_TOKEN=
PHONEBELL_OPEN_URL=
DASHBOARD_URL=

# Privacy service
PRIVACY_DB_URL=
PRIVACY_DB_API_KEY=

# Groq (voice transcription)
GROQ_API_KEY=

# Ships database (Turso / libsql)
SHIP_DATABASE_URL=
