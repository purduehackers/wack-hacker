# Discord
DISCORD_BOT_TOKEN=
DISCORD_BOT_CLIENT_ID=
DISCORD_BOT_PUBLIC_KEY=

# Internal auth
# Vercel cron invocations send `Authorization: Bearer ${CRON_SECRET}`; must match this.
CRON_SECRET=

# GitHub App
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_ORG=purduehackers

# Linear
LINEAR_API_KEY=

# Notion
NOTION_TOKEN=

# Purdue Hackers Knowledge Base (ask.purduehackers.com)
PHACK_ASK_API_KEY=

# Dashboard + Phonebell (Purdue Hackers internal services)
PHACK_API_TOKEN=

# Privacy service
PRIVACY_DB_API_KEY=

# Groq (voice transcription)
GROQ_API_KEY=

# Ships gallery service (ships.purduehackers.com) — bot POSTs ships + attachments here
SHIP_API_KEY=

# Shared wack-hacker database (Turso / libsql)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Upstash Redis (Workflow DevKit + Chat SDK state)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel
VERCEL_API_TOKEN=
DASHBOARD_EDGE_CONFIG=

# SerpAPI (Amazon product search via the shopping subagent)
SERPAPI_API_KEY=

# Resend (outreach email send + webhook)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Hunter.io (email enrichment)
HUNTER_API_KEY=

# Payload CMS (cms.purduehackers.com — service-account API key)
PAYLOAD_CMS_API_KEY=

# Exa (web search)
EXA_API_KEY=
